{
  "info": {
    "name": "Flood Rescue API",
    "_postman_id": "flood-rescue-collection",
    "description": "Complete API test collection for Flood Rescue Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "coordinator_token", "value": "" },
    { "key": "request_id", "value": "" },
    { "key": "test_email", "value": "" },
    { "key": "test_phone", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register Citizen",
          "event": [
            { "listen": "prerequest", "script": { "exec": ["const ts = Date.now().toString().slice(-8);", "pm.collectionVariables.set('test_email', 'test' + ts + '@gmail.com');", "pm.collectionVariables.set('test_phone', '09' + ts);"] } },
            { "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Success message', () => pm.expect(pm.response.json().message).to.include('th\u00e0nh c\u00f4ng'));"] } }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api","auth","register"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"password\": \"Test@1234\",\n  \"fullName\": \"Nguyen Van A\",\n  \"phone\": \"{{test_phone}}\"\n}" }
          }
        },
        {
          "name": "Login - Citizen",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Has token', () => pm.expect(pm.response.json()).to.have.property('token'));", "const t = pm.response.json().token; if(t) pm.collectionVariables.set('token', t);"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"identifier\": \"{{test_email}}\",\n  \"password\": \"Test@1234\"\n}" }
          }
        },
        {
          "name": "Login - Coordinator (Seed)",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Has token', () => pm.expect(pm.response.json()).to.have.property('token'));", "const t = pm.response.json().token; if(t) pm.collectionVariables.set('coordinator_token', t);"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"identifier\": \"conchimcu@gmail.com\",\n  \"password\": \"Anhtu2003\"\n}" }
          }
        },
        {
          "name": "Login - Wrong Password (expect 401)",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Rejects wrong password', () => pm.expect(pm.response.code).to.be.oneOf([400,401,403]));"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"identifier\": \"{{test_email}}\",\n  \"password\": \"WrongPass\"\n}" }
          }
        }
      ]
    },
    {
      "name": "2. Rescue - Citizen",
      "item": [
        {
          "name": "Create Rescue Request",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Has id', () => pm.expect(pm.response.json()).to.have.property('id'));", "const id = pm.response.json().id; if(id) pm.collectionVariables.set('request_id', String(id));"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/rescue/citizen/requests", "host": ["{{base_url}}"], "path": ["api","rescue","citizen","requests"] },
            "body": { "mode": "raw", "raw": "{\n  \"description\": \"Nha bi ngap lu, can cuu ho gap!\",\n  \"addressText\": \"123 Duong ABC, Da Nang\",\n  \"affectedPeopleCount\": 3,\n  \"priority\": \"HIGH\",\n  \"attachments\": []\n}" }
          }
        },
        {
          "name": "Get My Rescue Requests",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Returns page', () => pm.expect(pm.response.json()).to.have.property('content'));"] } }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/rescue/citizen/requests", "host": ["{{base_url}}"], "path": ["api","rescue","citizen","requests"] }
          }
        },
        {
          "name": "Get Rescue Request By ID",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Correct ID', () => pm.expect(String(pm.response.json().id)).to.equal(pm.collectionVariables.get('request_id')));"] } }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/rescue/citizen/requests/{{request_id}}", "host": ["{{base_url}}"], "path": ["api","rescue","citizen","requests","{{request_id}}"] }
          }
        },
        {
          "name": "Unauthorized - No Token (expect 401)",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('401 without token', () => pm.response.to.have.status(401));"] } }],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/rescue/citizen/requests", "host": ["{{base_url}}"], "path": ["api","rescue","citizen","requests"] }
          }
        }
      ]
    },
    {
      "name": "3. Rescue - Coordinator",
      "item": [
        {
          "name": "Get All Rescue Requests",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Returns page', () => pm.expect(pm.response.json()).to.have.property('content'));"] } }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{coordinator_token}}" }],
            "url": { "raw": "{{base_url}}/api/rescue/coordinator/requests", "host": ["{{base_url}}"], "path": ["api","rescue","coordinator","requests"] }
          }
        },
        {
          "name": "Get Rescue Requests - Filter by Status PENDING",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{coordinator_token}}" }],
            "url": { "raw": "{{base_url}}/api/rescue/coordinator/requests?status=PENDING", "host": ["{{base_url}}"], "path": ["api","rescue","coordinator","requests"], "query": [{ "key": "status", "value": "PENDING" }] }
          }
        },
        {
          "name": "Prioritize Rescue Request",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{coordinator_token}}" }],
            "url": { "raw": "{{base_url}}/api/rescue/coordinator/requests/{{request_id}}/priority", "host": ["{{base_url}}"], "path": ["api","rescue","coordinator","requests","{{request_id}}","priority"] },
            "body": { "mode": "raw", "raw": "{\n  \"priority\": \"HIGH\"\n}" }
          }
        },
        {
          "name": "Verify Rescue Request (Approve)",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{coordinator_token}}" }],
            "url": { "raw": "{{base_url}}/api/rescue/coordinator/requests/{{request_id}}/verify", "host": ["{{base_url}}"], "path": ["api","rescue","coordinator","requests","{{request_id}}","verify"] },
            "body": { "mode": "raw", "raw": "{\n  \"locationVerified\": true,\n  \"note\": \"Da xac nhan, uu tien xu ly\"\n}" }
          }
        }
      ]
    },
    {
      "name": "4. Map",
      "item": [
        {
          "name": "Get All Team Locations",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"] } }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/map/teams/locations", "host": ["{{base_url}}"], "path": ["api","map","teams","locations"] }
          }
        },
        {
          "name": "Find Nearest Teams",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/map/teams/nearest?lat=16.05&lng=108.20&radius=10", "host": ["{{base_url}}"], "path": ["api","map","teams","nearest"], "query": [{ "key": "lat", "value": "16.05" }, { "key": "lng", "value": "108.20" }, { "key": "radius", "value": "10" }] }
          }
        }
      ]
    },
    {
      "name": "5. Rescuer Tasks",
      "item": [
        {
          "name": "Get Tasks (IN_PROGRESS)",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/rescue/rescuer/tasks", "host": ["{{base_url}}"], "path": ["api","rescue","rescuer","tasks"] }
          }
        }
      ]
    },
    {
      "name": "6. Teams",
      "item": [
        {
          "name": "Get Team Requests",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200 or 404', () => pm.expect(pm.response.code).to.be.oneOf([200, 404]));"] } }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{coordinator_token}}" }],
            "url": { "raw": "{{base_url}}/api/teams/1/requests", "host": ["{{base_url}}"], "path": ["api","teams","1","requests"] }
          }
        }
      ]
    }
  ]
}
